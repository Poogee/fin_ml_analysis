    table.hline(stroke: 1pt),
    [*Модель*], [*Корр. с EW*], [*Избыточная дох. vs EW*],
    table.hline(stroke: 0.5pt),
    [RL Full Pipeline], [0.997], [+0.01%/год],
    [RL Full 2M steps], [0.997], [+0.36%/год],
